{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arckit.local/schema/project-state-record.schema.json",
  "title": "Arckit Project State Record",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "active_iteration_ref",
    "active_case_refs",
    "dimensions",
    "decisions",
    "open_questions",
    "project_memory",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "const": "project-state-record/v1" },
    "project": {
      "type": "object",
      "required": ["name", "status", "created_at", "updated_at", "original_intent"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "archived"]
        },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "original_intent": { "type": "string" }
      },
      "additionalProperties": true
    },
    "active_iteration_ref": { "type": "string" },
    "active_case_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dimensions": {
      "type": "object",
      "required": [
        "project_goal",
        "target_users",
        "core_scenarios",
        "platform_targets",
        "client_surface",
        "server_need",
        "account_identity",
        "data_persistence",
        "sync_collaboration",
        "deployment_distribution",
        "quality_bar",
        "technical_foundation",
        "iteration_strategy"
      ],
      "properties": {
        "project_goal": { "$ref": "#/$defs/dimension_state" },
        "target_users": { "$ref": "#/$defs/dimension_state" },
        "core_scenarios": { "$ref": "#/$defs/dimension_state" },
        "platform_targets": { "$ref": "#/$defs/dimension_state" },
        "client_surface": { "$ref": "#/$defs/dimension_state" },
        "server_need": { "$ref": "#/$defs/dimension_state" },
        "account_identity": { "$ref": "#/$defs/dimension_state" },
        "data_persistence": { "$ref": "#/$defs/dimension_state" },
        "sync_collaboration": { "$ref": "#/$defs/dimension_state" },
        "deployment_distribution": { "$ref": "#/$defs/dimension_state" },
        "quality_bar": { "$ref": "#/$defs/dimension_state" },
        "technical_foundation": { "$ref": "#/$defs/dimension_state" },
        "iteration_strategy": { "$ref": "#/$defs/dimension_state" }
      },
      "additionalProperties": false
    },
    "decisions": { "type": "array" },
    "open_questions": { "type": "array" },
    "project_memory": { "type": "array" },
    "artifacts": { "type": "array" },
    "last_project_state_delta": { "$ref": "#/$defs/project_state_delta" }
  },
  "$defs": {
    "dimension_state": {
      "type": "object",
      "required": ["status", "reason", "evidence", "next"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["unknown", "needed", "satisfied", "not_applicable", "deferred", "blocked"]
        },
        "reason": { "type": "string" },
        "evidence": { "type": "array" },
        "evidence_maturity": {
          "type": "string",
          "enum": ["none", "exploratory", "confirmed", "formalized"]
        },
        "next": { "type": "string" }
      },
      "additionalProperties": true
    },
    "project_state_delta": {
      "type": "object",
      "required": ["changed", "unchanged_unknown", "deferred", "blocked", "next_project_question", "updated_at"],
      "properties": {
        "changed": { "type": "array" },
        "unchanged_unknown": { "type": "array" },
        "deferred": { "type": "array" },
        "blocked": { "type": "array" },
        "next_project_question": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
