{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arckit.local/schema/controller-review.schema.json",
  "title": "Arckit Controller Review",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "summary",
    "accepted_reports",
    "rejected_reports",
    "risks",
    "unknowns",
    "next_prompt",
    "continuation_intent",
    "human_decision_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "arckit-controller-review/v1" },
    "status": {
      "type": "string",
      "enum": ["done", "continue", "needs_human", "blocked"]
    },
    "summary": { "type": "string", "maxLength": 1200 },
    "accepted_reports": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rejected_reports": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string", "maxLength": 1200 }
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string", "maxLength": 1200 }
    },
    "next_prompt": { "type": "string", "maxLength": 1200 },
    "continuation_intent": {
      "type": "object",
      "required": ["goal", "state_transition", "next_prompt"],
      "properties": {
        "goal": { "type": "string", "minLength": 1, "maxLength": 800 },
        "state_transition": { "type": "string", "minLength": 1, "maxLength": 800 },
        "next_prompt": { "type": "string", "minLength": 1, "maxLength": 1200 }
      },
      "additionalProperties": false
    },
    "human_decision_required": { "type": "boolean" }
  },
  "additionalProperties": false
}
