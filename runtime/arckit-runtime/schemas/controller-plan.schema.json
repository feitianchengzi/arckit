{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arckit.local/schema/controller-plan.schema.json",
  "title": "Arckit Controller Plan",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "summary",
    "route_plan",
    "worker_intents",
    "continuation_intent",
    "risks",
    "unknowns",
    "next_controller_action"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "arckit-controller-plan/v1" },
    "status": {
      "type": "string",
      "enum": ["planned", "needs_human", "blocked"]
    },
    "summary": { "type": "string", "maxLength": 1200 },
    "route_plan": {
      "type": "object",
      "required": [
        "mode",
        "selected_gap",
        "selected_worker_types",
        "selected_roles",
        "reason",
        "requires_human_confirmation"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "selected_gap": {
          "type": "object",
          "required": [
            "id",
            "dimension",
            "current_state",
            "target_state",
            "urgency",
            "risk",
            "impact",
            "next_transition"
          ],
          "properties": {
            "id": { "type": "string" },
            "dimension": { "type": "string" },
            "current_state": { "type": "string", "maxLength": 1200 },
            "target_state": { "type": "string", "maxLength": 1200 },
            "urgency": { "type": "string" },
            "risk": { "type": "string" },
            "impact": { "type": "string", "maxLength": 1200 },
            "next_transition": { "type": "string", "maxLength": 800 }
          },
          "additionalProperties": false
        },
        "selected_roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "selected_worker_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["product", "tech", "implementation", "verification", "diagnosis", "closeout"]
          }
        },
        "reason": { "type": "string", "maxLength": 1200 },
        "requires_human_confirmation": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "worker_intents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["worker_type", "role", "objective", "reason", "allowed_skills"],
        "properties": {
          "worker_type": {
            "type": "string",
            "enum": ["product", "tech", "implementation", "verification", "diagnosis", "closeout"]
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "objective": { "type": "string", "maxLength": 800 },
          "reason": { "type": "string", "maxLength": 1200 },
          "allowed_skills": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "continuation_intent": {
      "type": "object",
      "required": ["goal", "state_transition", "next_prompt"],
      "properties": {
        "goal": { "type": "string", "minLength": 1, "maxLength": 800 },
        "state_transition": { "type": "string", "minLength": 1, "maxLength": 800 },
        "next_prompt": { "type": "string", "minLength": 1, "maxLength": 1200 }
      },
      "additionalProperties": false
    },
    "risks": {
      "type": "array",
      "items": { "type": "string", "maxLength": 1200 }
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string", "maxLength": 1200 }
    },
    "next_controller_action": { "type": "string", "maxLength": 1200 }
  },
  "additionalProperties": false
}
